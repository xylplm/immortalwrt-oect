# Defaults used by the scheduled GitHub Actions build.
# Manual workflow inputs can override selected values.

# Official ImmortalWrt rootfs target used by ImageBuilder.
IMMORTALWRT_ROOTFS_TARGET=armsr/armv8
IMMORTALWRT_ROOTFS_PROFILE=generic

# Device board name used by ophub/amlogic-s9xxx-openwrt packer.
IMMORTALWRT_BOARD=wxy-oect
IMMORTALWRT_VARIANTS="base plus bypass"

# Final image rootfs partition sizes in MiB.
# ophub's packer requires rootfs >= 1024 MiB.
IMMORTALWRT_BASE_ROOTFS_PARTSIZE=1280
IMMORTALWRT_PLUS_ROOTFS_PARTSIZE=2048
IMMORTALWRT_BYPASS_ROOTFS_PARTSIZE=4096
